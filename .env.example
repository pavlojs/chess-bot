# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────

# Lichess API token — required scopes: board:play, bot:play
# Get yours at: https://lichess.org/account/oauth/token
TOKEN="your_lichess_token_here"

# ─────────────────────────────────────────────
# STOCKFISH SETUP (optional)
# ─────────────────────────────────────────────

# Auto-download and install latest Stockfish on startup (default: true)
# AUTO_UPDATE_STOCKFISH=true

# Path to a custom Stockfish binary (auto-detected if not set)
# STOCKFISH_PATH="/usr/local/bin/stockfish"

# ─────────────────────────────────────────────
# ENGINE PERFORMANCE (optional)
# ─────────────────────────────────────────────

# CPU threads for Stockfish (default: 4)
# SF_THREADS=4

# Hash table size in MB (default: 2048 = 2 GB)
# SF_HASH=2048

# Network latency compensation in ms (default: 30)
# SF_MOVE_OVERHEAD=30

# Base thinking time per move in ms — used for weak opponents and fallback (default: 3000)
# STOCKFISH_TIME=3000

# ─────────────────────────────────────────────
# DYNAMIC STRENGTH SYSTEM (optional)
# ─────────────────────────────────────────────
#
# UCI_LimitStrength is active for ALL opponents below FULL_STRENGTH_THRESHOLD.
# The engine is capped at opponent_rating + STRENGTH_ADVANTAGE ELO (no blunders).
# go movetime is used (not native clocks) to guarantee fast replies and prevent
# Lichess abort timeouts.
#
# Tiers:
#   < LIMIT_STRENGTH_THRESHOLD   → UCI_LimitStrength at opponent+bonus + 40% movetime (fair, winnable)
#   LIMIT – FULL threshold       → UCI_LimitStrength at opponent+bonus + 40-95% movetime (beatable)
#   >= FULL_STRENGTH_THRESHOLD   → Full power, native clocks, no handicap
#
# Enable/disable the entire dynamic strength system (default: true)
# DYNAMIC_STRENGTH=true

# Boundary between minimal-time zone and scaled-time zone (default: 1800)
# Below: 40% movetime.  Between this and FULL_STRENGTH_THRESHOLD: 40-95% scaled.
# LIMIT_STRENGTH_THRESHOLD=1800

# At or above this rating: UCI_LimitStrength OFF, native clocks, full engine power (default: 2800)
# FULL_STRENGTH_THRESHOLD=2800

# ELO bonus: bot plays at opponent_rating + bonus for all below FULL_STRENGTH_THRESHOLD (default: 100)
# STRENGTH_ADVANTAGE=100

# ─────────────────────────────────────────────
# MOVE PREDICTION / ANALYSIS (optional)
# ─────────────────────────────────────────────

# Show Stockfish's planned continuation in logs (default: true)
# No extra engine call — extracted from the normal search info line at zero cost
# ENABLE_MOVE_PREDICTION=true

# Number of half-moves to display in the predicted line (default: 10)
# PREDICTION_DEPTH=10

# If prediction is active and the predicted evaluation for the bot is worse
# than this threshold (in centipawns), the bot will attempt a recovery search
# (longer movetime for movetime mode or alternative search for native-clock games)
# PREDICTION_RECOVER_THRESHOLD=400

# ─────────────────────────────────────────────
# AUTO-CHALLENGE (optional)
# ─────────────────────────────────────────────

# Automatically challenge other bots when idle (default: true)
# ENABLE_AUTO_CHALLENGE=true

# Maximum outgoing challenges per hour (default: 5)
# MAX_CHALLENGES_PER_HOUR=5

# ELO range for target bots (defaults: 1500–2900)
# CHALLENGE_MIN_RATING=1500
# CHALLENGE_MAX_RATING=2900

# Idle poll interval when no challenge is pending, in seconds (default: 60)
# CHALLENGE_CHECK_INTERVAL=60