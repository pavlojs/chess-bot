# Lichess API Token (required)
# Get your token from: https://lichess.org/account/oauth/token
# Required scopes: board:play, bot:play
TOKEN="your_lichess_token_here"

# Auto-update Stockfish (optional - default: true)
# When enabled, bot will automatically download and install latest Stockfish on startup
# Uses the same method as Docker build for consistency
# AUTO_UPDATE_STOCKFISH=true

# Stockfish Path (optional - auto-detected if not set)
# The bot will automatically install/update Stockfish to /usr/local/bin/stockfish
# Only set this if you want to use a different Stockfish binary
# STOCKFISH_PATH="/path/to/stockfish"

# ─────────────────────────────────────────────
# CHALLENGE CONFIGURATION
# ─────────────────────────────────────────────

# Enable automatic challenging of other bots (optional - default: true)
# When enabled and no games are active, the bot will challenge other bots
# ENABLE_AUTO_CHALLENGE=true

# Maximum number of challenges to send per hour (optional - default: 3)
# MAX_CHALLENGES_PER_HOUR=3

# ELO range for challenging bots (optional - defaults: 1500-2900)
# Bot will only challenge bots within this rating range
# CHALLENGE_MIN_RATING=1500
# CHALLENGE_MAX_RATING=2900

# How often to check for challenging opportunities in seconds (optional - default: 300)
# Bot checks every 5 minutes by default
# CHALLENGE_CHECK_INTERVAL=300